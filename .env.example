DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_TIME_ZONE=UTC

POSTGRES_DB=walkie
POSTGRES_USER=walkie
POSTGRES_PASSWORD=walkie
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false

CORS_ALLOW_ALL_ORIGINS=true
MEDIA_ROOT=media
MEDIA_URL=/media/

STT_PROVIDER=groq
TRANSLATION_PROVIDER=groq
TTS_PROVIDER=elevenlabs

GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_HINTED_MODEL=whisper-large-v3
GROQ_STT_ALLOWED_AUTO_LANGUAGES=en,hi
GROQ_TRANSLATION_MODEL=llama-3.3-70b-versatile

SARVAM_API_KEY=replace-with-your-sarvam-api-key
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_TRANSLATION_MODEL=sarvam-translate:v1
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_PACE=1.0
SARVAM_TTS_AUDIO_FORMAT=wav
FFMPEG_BINARY=ffmpeg
TRANSLATION_FANOUT_MAX_WORKERS=4

ELEVENLABS_API_KEY=replace-with-your-elevenlabs-api-key
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_TTS_VOICE_ID=RXe6OFmxoC0nlSWpuCDy
ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TTS_MAX_RETRIES=2
ELEVENLABS_TTS_RETRY_BASE_DELAY=0.5
